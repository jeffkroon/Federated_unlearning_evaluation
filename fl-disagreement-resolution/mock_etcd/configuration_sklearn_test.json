{
  "experiment": {
    "type": "mnist",
    "fl_rounds": 2,
    "client_ids": [0, 1, 2],
    "iid": true
  },
  "data": {
    "train_dir": {
      "n_cmapss": "data/n-cmapss/train",
      "mnist": "data/mnist/train"
    },
    "test_dir": {
      "n_cmapss": "data/n-cmapss/test",
      "mnist": "data/mnist/test"
    },
    "test_units": [11, 14, 15],
    "client_sample_size": 100,
    "test_sample_size": 100,
    "setup_data": true,
    "force_setup_data": false
  },
  "training": {
    "batch_size": 64,
    "local_epochs": 1,
    "learning_rate": 0.001
  },
  "disagreement": {
    "initiation_mechanism": "shallow",
    "lifting_mechanism": "shallow",
    "deep_lifting_finetune_rounds": 3
  },
  "unlearning": {
    "enabled": false,
    "model_type": "random_forest",
    "strategies": ["exact_retraining", "sisa", "distillation"],
    "use_strategy": "exact_retraining",
    "reuse_existing_branches": true,
    "model_params": {
      "n_estimators": 10,
      "max_depth": 5
    },
    "train_params": {
      "epochs": 10,
      "batch_size": 64,
      "lr": 0.001
    }
  },
  "results": {
    "use_timestamped_dir": false,
    "base_dir": "results_sklearn_test",
    "structure": {
      "model_storage_dir": "model_storage_sklearn",
      "global_model_initial": "model_storage_sklearn/global_model_initial",
      "round_template": "model_storage_sklearn/round_{round}",
      "clients_dir": "clients",
      "global_model": "global_model_for_training",
      "global_model_aggregated": "global_model_aggregated",
      "output_dir": "output",
      "client_prefix": "client_"
    }
  }
}

